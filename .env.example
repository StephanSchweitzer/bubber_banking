# Plaid — from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_or_production_secret
PLAID_ENV=sandbox

# Google service account JSON key (path, relative or absolute)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# The target spreadsheet's ID (from its URL: /spreadsheets/d/<SHEET_ID>/edit)
SHEET_ID=your_google_sheet_id

# Optional: port for the `npm run link` bootstrap server (default 4000)
# LINK_PORT=4000
